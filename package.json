{
  "name": "ankicode",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "workspaces": [
    "extension"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "build:extension": "npm run build --workspace @ankicode/extension",
    "typecheck": "tsc --noEmit --pretty false && tsc --noEmit --pretty false -p tsconfig.test.json && tsc --noEmit --pretty false -p tsconfig.node.json",
    "typecheck:extension": "npm run typecheck --workspace @ankicode/extension",
    "lint": "eslint . --max-warnings 0 --ignore-pattern 'extension/dist/**'",
    "format": "prettier --write . && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:check": "prettier --check . && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "test": "vitest run",
    "test:extension": "npm run test --workspace @ankicode/extension",
    "test:watch": "vitest",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:extension && npm run test && npm run test:extension && npm run build && npm run build:extension && npm run test:rust",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
